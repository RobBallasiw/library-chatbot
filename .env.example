# Groq API Configuration (Get your free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Facebook Messenger Configuration
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# Server Configuration
PORT=3000
WEBHOOK_URL=https://your-domain.com/webhook
NODE_ENV=production

# Librarian Access Configuration
# Comma-separated list of Facebook PSIDs authorized to receive librarian notifications
# Example: LIBRARIAN_PSID=123456789,987654321
LIBRARIAN_PSID=

# Secret keyword users must message to request librarian access
# Change this to something only your staff would know
LIBRARIAN_REQUEST_KEYWORD=REQUEST_LIBRARIAN_ACCESS

# REQUIRED: Admin Dashboard Password
# IMPORTANT: Change this to a secure password before deploying to production
# This password protects the admin dashboard at /admin
ADMIN_PASSWORD=

# REQUIRED: Librarian Dashboard Password
# IMPORTANT: Change this to a secure password before deploying to production
# This password protects the librarian dashboard at /librarian and /librarian-mobile
LIBRARIAN_PASSWORD=
